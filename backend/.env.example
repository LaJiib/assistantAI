# Chemin vers le modèle Ministral (OBLIGATOIRE)
MODEL_PATH=/Volumes/AISSD/models/gemma-4-26b-a4b-it-8bit
DATA_FOLDER=/Volumes/AISSD/conversations
# Dossier de persistance des outils (registry.json + métadonnées tools)
# Si vide : auto-résolu à côté de DATA_FOLDER (ex: /Volumes/AISSD/tools_registry)
TOOLS_FOLDER=/Volumes/AISSD/tools_registry
# Nombre max de tokens générés par réponse (plafond serveur global)
MAX_GENERATION_TOKENS=4096
# Paramètres de sampling (0.0 / 0 = désactivé → argmax si temp=0)
GENERATION_TEMPERATURE=1
GENERATION_TOP_P=0.95
GENERATION_TOP_K=64
# Serveur — bind localhost uniquement (ne pas changer en prod)
HOST=127.0.0.1
PORT=8000

# Logs : info | debug
LOG_LEVEL=info
